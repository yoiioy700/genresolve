# ============================================================
# GenResolve - Environment Variables
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# ============================================================

# Your deployer wallet private key (with 0x prefix)
# ⚠️  NEVER commit the real .env to git!
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# GenLayer network to deploy to.
# Options:
#   testnet-bradbury  → Official hackathon testnet
#   simulator         → Local GenLayer simulator (docker)
NETWORK=testnet-bradbury

# RPC endpoint URL.
# Bradbury testnet default is already baked into the script.
# Override here only if you use a custom node or the simulator.
RPC_URL=https://rpc.testnet.genlayer.com
